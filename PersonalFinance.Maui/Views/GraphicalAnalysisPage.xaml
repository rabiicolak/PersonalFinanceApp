<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PersonalFinance.Maui.Views.GraphicalAnalysisPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PersonalFinance.Maui.Views"
    Title="Grafiksel Analiz"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout
            x:Name="MainContentLayout"
            Padding="22"
            Spacing="24"
            MaximumWidthRequest="760"
            HorizontalOptions="Center"
            Opacity="0">

            <Grid ColumnDefinitions="Auto,*">
                <Button
                    Text="←"
                    Clicked="OnBackClicked"
                    BackgroundColor="{DynamicResource Secondary}"
                    TextColor="{DynamicResource PrimaryDark}"
                    HeightRequest="44"
                    WidthRequest="44"
                    CornerRadius="22"
                    FontAttributes="Bold"
                    FontSize="22"
                    Padding="0" />

                <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" Spacing="3">
                    <Label
                        Text="Grafiksel Finans Analizi"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="{DynamicResource PrimaryDark}" />

                    <Label
                        Text="Gelir ve gider dağılımınızın görsel analizi."
                        FontSize="13"
                        TextColor="{DynamicResource TextSecondary}" />
                </VerticalStackLayout>
            </Grid>

            <Frame
                Padding="28"
                CornerRadius="32"
                BackgroundColor="{DynamicResource CardBackground}"
                HasShadow="True"
                BorderColor="{DynamicResource BorderSoft}">

                <VerticalStackLayout Spacing="24">
                    <Label
                        Text="Gelir / Gider Dağılımı"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{DynamicResource TextPrimary}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="22">
                        <Grid
                            HeightRequest="260"
                            WidthRequest="260"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <GraphicsView
                                x:Name="DonutGraphicsView"
                                HeightRequest="260"
                                WidthRequest="260" />

                            <VerticalStackLayout
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Spacing="4">

                                <Label
                                    Text="Toplam Akış"
                                    FontSize="13"
                                    TextColor="{DynamicResource TextSecondary}"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    x:Name="TotalFlowLabel"
                                    Text="0 ₺"
                                    FontSize="28"
                                    FontAttributes="Bold"
                                    TextColor="{DynamicResource TextPrimary}"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="18"
                            VerticalOptions="Center"
                            WidthRequest="130">

                            <Frame
                                BackgroundColor="#ECFDF5"
                                BorderColor="#10B981"
                                CornerRadius="20"
                                Padding="14,12"
                                HasShadow="False">

                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <Frame
                                            HeightRequest="12"
                                            WidthRequest="12"
                                            CornerRadius="6"
                                            Padding="0"
                                            BackgroundColor="{DynamicResource IncomeColor}"
                                            HasShadow="False" />

                                        <Label
                                            Text="Gelir"
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            TextColor="#1E1B4B" />
                                    </HorizontalStackLayout>

                                    <Label
                                        x:Name="IncomePercentageLabel"
                                        Text="Gelir: %0"
                                        FontSize="13"
                                        TextColor="#6B5E86" />
                                </VerticalStackLayout>
                            </Frame>

                            <Frame
                                BackgroundColor="#FEF2F2"
                                BorderColor="#EF4444"
                                CornerRadius="20"
                                Padding="14,12"
                                HasShadow="False">

                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <Frame
                                            HeightRequest="12"
                                            WidthRequest="12"
                                            CornerRadius="6"
                                            Padding="0"
                                            BackgroundColor="{DynamicResource ExpenseColor}"
                                            HasShadow="False" />

                                        <Label
                                            Text="Gider"
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            TextColor="#1E1B4B" />
                                    </HorizontalStackLayout>

                                    <Label
                                        x:Name="ExpensePercentageLabel"
                                        Text="Gider: %0"
                                        FontSize="13"
                                        TextColor="#6B5E86" />
                                </VerticalStackLayout>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                CornerRadius="28"
                BackgroundColor="{DynamicResource CardBackground}"
                HasShadow="True"
                BorderColor="{DynamicResource BorderSoft}">

                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Finansal Özet"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{DynamicResource TextPrimary}" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Gelir Oranı" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" />
                            <Label x:Name="IncomeRatioLabel" Text="%0" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource IncomeColor}" HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Gider Oranı" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" />
                            <Label x:Name="ExpenseRatioLabel" Text="%0" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource ExpenseColor}" HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Toplam Akış" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" />
                            <Label x:Name="TotalVolumeLabel" Text="0 ₺" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource Primary}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame
                Padding="20"
                CornerRadius="28"
                BackgroundColor="{DynamicResource CardBackground}"
                HasShadow="True"
                BorderColor="{DynamicResource BorderSoft}">

                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="📅 Aylık Takip Grafiği"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{DynamicResource TextPrimary}" />

                    <CollectionView x:Name="MonthlyAnalysisCollectionView">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="20" HorizontalOptions="Center">
                                <Label
                                    Text="Aylık analiz için işlem bulunmuyor."
                                    TextColor="{DynamicResource TextMuted}"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="views:MonthlyAnalysisItem">
                                <Frame
                                    Padding="16"
                                    Margin="0,0,0,14"
                                    CornerRadius="20"
                                    BackgroundColor="{DynamicResource PageBackground}"
                                    BorderColor="{DynamicResource BorderSoft}"
                                    HasShadow="False">

                                    <VerticalStackLayout Spacing="14">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label
                                                Text="{Binding MonthYearName}"
                                                FontSize="16"
                                                FontAttributes="Bold"
                                                TextColor="{DynamicResource TextPrimary}" />

                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding NetBalanceFormatted}"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                TextColor="{Binding NetBalanceColor}" />
                                        </Grid>

                                        <Grid
                                            ColumnDefinitions="*,*"
                                            ColumnSpacing="34"
                                            HeightRequest="180"
                                            HorizontalOptions="Center">

                                            <VerticalStackLayout
                                                Grid.Column="0"
                                                Spacing="8"
                                                HorizontalOptions="Center"
                                                VerticalOptions="End">

                                                <Grid HeightRequest="125" WidthRequest="60">
                                                    <Frame
                                                        VerticalOptions="End"
                                                        HeightRequest="{Binding IncomeBarHeight}"
                                                        WidthRequest="46"
                                                        CornerRadius="13"
                                                        BackgroundColor="{DynamicResource IncomeColor}"
                                                        BorderColor="Transparent"
                                                        Padding="0"
                                                        HasShadow="False" />
                                                </Grid>

                                                <Label Text="Gelir" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource IncomeColor}" HorizontalOptions="Center" />
                                                <Label Text="{Binding TotalIncomeFormatted}" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Spacing="8"
                                                HorizontalOptions="Center"
                                                VerticalOptions="End">

                                                <Grid HeightRequest="125" WidthRequest="60">
                                                    <Frame
                                                        VerticalOptions="End"
                                                        HeightRequest="{Binding ExpenseBarHeight}"
                                                        WidthRequest="46"
                                                        CornerRadius="13"
                                                        BackgroundColor="{DynamicResource ExpenseColor}"
                                                        BorderColor="Transparent"
                                                        Padding="0"
                                                        HasShadow="False" />
                                                </Grid>

                                                <Label Text="Gider" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource ExpenseColor}" HorizontalOptions="Center" />
                                                <Label Text="{Binding TotalExpenseFormatted}" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Label
                                            Text="Aylık gelir ve gider karşılaştırması"
                                            FontSize="11"
                                            TextColor="{DynamicResource TextMuted}"
                                            HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>