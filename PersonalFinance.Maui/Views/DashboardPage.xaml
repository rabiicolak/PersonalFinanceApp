<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PersonalFinance.Maui.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dashboard"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout
            Padding="22"
            Spacing="18"
            MaximumWidthRequest="520"
            HorizontalOptions="Center">

            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                    <Label
                        x:Name="WelcomeLabel"
                        Text="Merhaba! 👋"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="{StaticResource PrimaryDark}" />

                    <Label
                        Text="Finansal durumunuz kontrol altında."
                        FontSize="13"
                        TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                    <Button
                        Text="Şifre"
                        Clicked="OnChangePasswordClicked"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource PrimaryDark}"
                        BorderColor="{StaticResource BorderSoft}"
                        BorderWidth="1"
                        CornerRadius="14"
                        FontSize="11"
                        FontAttributes="Bold"
                        Padding="12,4"
                        HeightRequest="36" />

                    <Button
                        Text="Çıkış"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="#FEE2E2"
                        TextColor="{StaticResource ExpenseColor}"
                        BorderColor="#FCA5A5"
                        BorderWidth="1"
                        CornerRadius="14"
                        FontSize="11"
                        FontAttributes="Bold"
                        Padding="12,4"
                        HeightRequest="36" />
                </HorizontalStackLayout>
            </Grid>

            <Frame
                Padding="22"
                CornerRadius="28"
                HasShadow="True"
                BorderColor="Transparent"
                BackgroundColor="{StaticResource Primary}">

                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label
                                Text="Toplam Bakiye"
                                FontSize="13"
                                TextColor="#EDE9FE"
                                FontAttributes="Bold" />

                            <Label
                                x:Name="TotalBalanceLabel"
                                Text="0,00 ₺"
                                FontSize="34"
                                FontAttributes="Bold"
                                TextColor="White" />
                        </VerticalStackLayout>

                        <Frame
                            Grid.Column="1"
                            HeightRequest="46"
                            WidthRequest="46"
                            CornerRadius="23"
                            Padding="0"
                            BackgroundColor="#ffffff22"
                            HasShadow="False"
                            BorderColor="Transparent"
                            VerticalOptions="Center">

                            <Label
                                Text="👛"
                                FontSize="22"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Frame>
                    </Grid>

                    <Label
                        Text="Gelir ve gider hareketlerinize göre güncel bakiyeniz."
                        FontSize="12"
                        TextColor="#F5F3FF" />
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Frame
                    Grid.Column="0"
                    Padding="18"
                    CornerRadius="22"
                    HasShadow="True"
                    BorderColor="Transparent"
                    BackgroundColor="{StaticResource CardBackground}">

                    <VerticalStackLayout Spacing="8">
                        <Frame
                            HeightRequest="38"
                            WidthRequest="38"
                            CornerRadius="19"
                            Padding="0"
                            BackgroundColor="#D1FAE5"
                            HasShadow="False"
                            BorderColor="Transparent"
                            HorizontalOptions="Start">

                            <Label
                                Text="📈"
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Frame>

                        <Label
                            Text="Toplam Gelir"
                            FontSize="12"
                            TextColor="{StaticResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Label
                            x:Name="TotalIncomeLabel"
                            Text="0,00 ₺"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource IncomeColor}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="1"
                    Padding="18"
                    CornerRadius="22"
                    HasShadow="True"
                    BorderColor="Transparent"
                    BackgroundColor="{StaticResource CardBackground}">

                    <VerticalStackLayout Spacing="8">
                        <Frame
                            HeightRequest="38"
                            WidthRequest="38"
                            CornerRadius="19"
                            Padding="0"
                            BackgroundColor="#FEE2E2"
                            HasShadow="False"
                            BorderColor="Transparent"
                            HorizontalOptions="Start">

                            <Label
                                Text="📉"
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Frame>

                        <Label
                            Text="Toplam Gider"
                            FontSize="12"
                            TextColor="{StaticResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Label
                            x:Name="TotalExpenseLabel"
                            Text="0,00 ₺"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource ExpenseColor}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label
                        Text="Son İşlemler"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource PrimaryDark}" />

                    <Label
                        Text="En son eklediğiniz gelir ve giderler"
                        FontSize="12"
                        TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <Button
                    Grid.Column="1"
                    Text="Tümünü Gör"
                    Clicked="OnAllTransactionsClicked"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource PrimaryDark}"
                    FontSize="11"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    Padding="14,4"
                    HeightRequest="32"
                    VerticalOptions="Center" />
            </Grid>

            <VerticalStackLayout x:Name="TransactionsListLayout" Spacing="10">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            BackgroundColor="{StaticResource CardBackground}"
                            Padding="16,13"
                            CornerRadius="20"
                            HasShadow="True"
                            BorderColor="Transparent">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Frame
                                    Grid.Column="0"
                                    HeightRequest="42"
                                    WidthRequest="42"
                                    CornerRadius="21"
                                    BackgroundColor="{StaticResource Secondary}"
                                    Padding="0"
                                    HasShadow="False"
                                    BorderColor="Transparent"
                                    VerticalOptions="Center">

                                    <Label
                                        Text="{Binding CategoryIcon}"
                                        FontSize="18"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimary}" />

                                    <Label
                                        Text="{Binding DateFormatted}"
                                        FontSize="11"
                                        TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding AmountFormatted}"
                                    TextColor="{Binding AmountColor}"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <VerticalStackLayout
                x:Name="EmptyViewLayout"
                Padding="36"
                Spacing="10"
                HorizontalOptions="Center"
                IsVisible="False">

                <Label
                    Text="💸"
                    FontSize="42"
                    HorizontalOptions="Center" />

                <Label
                    Text="Henüz bir işlem bulunmuyor."
                    FontSize="13"
                    TextColor="{StaticResource TextSecondary}"
                    HorizontalOptions="Center" />

                <Label
                    Text="İlk gelir veya gider kaydınızı ekleyerek başlayın."
                    FontSize="12"
                    TextColor="{StaticResource TextMuted}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,16">
                <Button
                    Grid.Column="0"
                    Text="+ Yeni İşlem"
                    Clicked="OnAddTransactionClicked"
                    HeightRequest="52"
                    CornerRadius="16" />

                <Button
                    Grid.Column="1"
                    Text="📊 İstatistikler"
                    Clicked="OnStatisticsClicked"
                    BackgroundColor="White"
                    TextColor="{StaticResource PrimaryDark}"
                    BorderColor="{StaticResource BorderSoft}"
                    BorderWidth="1.5"
                    FontAttributes="Bold"
                    FontSize="14"
                    CornerRadius="16"
                    HeightRequest="52" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>