<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PersonalFinance.Maui.Views.ChangePasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Şifre Değiştir"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout
            Padding="22"
            Spacing="18"
            MaximumWidthRequest="480"
            HorizontalOptions="Center">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*" Margin="0,8,0,0">

                <Button
                    Grid.Column="0"
                    Text="←"
                    Clicked="OnBackClicked"
                    BackgroundColor="{DynamicResource Secondary}"
                    TextColor="{DynamicResource PrimaryDark}"
                    FontSize="20"
                    FontAttributes="Bold"
                    Padding="0"
                    HeightRequest="42"
                    WidthRequest="42"
                    CornerRadius="21"
                    VerticalOptions="Center" />

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="3"
                    Margin="12,0,0,0"
                    VerticalOptions="Center">

                    <Label
                        Text="Şifre Değiştir"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="{DynamicResource PrimaryDark}" />

                    <Label
                        Text="Hesabınızın güvenliğini korumak için şifrenizi güncelleyin."
                        FontSize="13"
                        TextColor="{DynamicResource TextSecondary}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Bilgi Kartı -->
            <Frame
                BackgroundColor="{DynamicResource Secondary}"
                BorderColor="{DynamicResource BorderSoft}"
                CornerRadius="22"
                Padding="16"
                HasShadow="False">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">

                    <Frame
                        Grid.Column="0"
                        HeightRequest="42"
                        WidthRequest="42"
                        CornerRadius="21"
                        BackgroundColor="White"
                        Padding="0"
                        HasShadow="False"
                        BorderColor="Transparent">

                        <Label
                            Text="🔐"
                            FontSize="20"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label
                            Text="Güvenlik önerisi"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="{DynamicResource PrimaryDark}" />

                        <Label
                            Text="Yeni şifreniz en az 6 karakter olmalıdır."
                            FontSize="12"
                            TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Form Kartı -->
            <Frame
                BackgroundColor="{DynamicResource CardBackground}"
                Padding="22"
                CornerRadius="24"
                HasShadow="True"
                BorderColor="Transparent">

                <VerticalStackLayout Spacing="18">

                    <!-- Eski Şifre -->
                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Eski Şifre *"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Frame
                            BackgroundColor="{DynamicResource InputBackground}"
                            BorderColor="{DynamicResource BorderSoft}"
                            CornerRadius="16"
                            Padding="14,0"
                            HeightRequest="52"
                            HasShadow="False">

                            <Entry
                                x:Name="OldPasswordEntry"
                                Placeholder="Mevcut şifrenizi girin"
                                IsPassword="True"
                                TextColor="{DynamicResource TextPrimary}"
                                PlaceholderColor="{DynamicResource TextMuted}"
                                VerticalOptions="Center" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Yeni Şifre -->
                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Yeni Şifre *"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Frame
                            BackgroundColor="{DynamicResource InputBackground}"
                            BorderColor="{DynamicResource BorderSoft}"
                            CornerRadius="16"
                            Padding="14,0"
                            HeightRequest="52"
                            HasShadow="False">

                            <Entry
                                x:Name="NewPasswordEntry"
                                Placeholder="En az 6 karakter"
                                IsPassword="True"
                                TextColor="{DynamicResource TextPrimary}"
                                PlaceholderColor="{DynamicResource TextMuted}"
                                VerticalOptions="Center" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Yeni Şifre Tekrar -->
                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Yeni Şifre Tekrar *"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Frame
                            BackgroundColor="{DynamicResource InputBackground}"
                            BorderColor="{DynamicResource BorderSoft}"
                            CornerRadius="16"
                            Padding="14,0"
                            HeightRequest="52"
                            HasShadow="False">

                            <Entry
                                x:Name="ConfirmNewPasswordEntry"
                                Placeholder="Yeni şifrenizi tekrar girin"
                                IsPassword="True"
                                TextColor="{DynamicResource TextPrimary}"
                                PlaceholderColor="{DynamicResource TextMuted}"
                                VerticalOptions="Center" />
                        </Frame>
                    </VerticalStackLayout>

                    <Button
                        Text="Şifreyi Güncelle"
                        Clicked="OnChangePasswordClicked"
                        HeightRequest="54"
                        CornerRadius="18"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
