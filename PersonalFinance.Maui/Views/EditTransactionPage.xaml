<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PersonalFinance.Maui.Views.EditTransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="İşlemi Düzenle"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout
            Padding="22"
            Spacing="18"
            MaximumWidthRequest="480"
            HorizontalOptions="Center">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*" Margin="0,8,0,0">

                <Button
                    Grid.Column="0"
                    Text="←"
                    Clicked="OnBackClicked"
                    BackgroundColor="{DynamicResource Secondary}"
                    TextColor="{DynamicResource PrimaryDark}"
                    FontSize="20"
                    FontAttributes="Bold"
                    Padding="0"
                    HeightRequest="42"
                    WidthRequest="42"
                    CornerRadius="21"
                    VerticalOptions="Center" />

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="3"
                    Margin="12,0,0,0"
                    VerticalOptions="Center">

                    <Label
                        Text="İşlemi Düzenle"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="{DynamicResource PrimaryDark}" />

                    <Label
                        Text="İşlem bilgilerini güncelleyin veya silin."
                        FontSize="13"
                        TextColor="{DynamicResource TextSecondary}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Ana Kart -->
            <Frame
                BackgroundColor="{DynamicResource CardBackground}"
                Padding="22"
                CornerRadius="24"
                HasShadow="True"
                BorderColor="Transparent">

                <VerticalStackLayout Spacing="18">

                    <!-- Tür -->
                    <VerticalStackLayout Spacing="8">

                        <Label
                            Text="İşlem Türü *"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                            <Frame
                                Grid.Column="0"
                                BackgroundColor="#ECFDF5"
                                BorderColor="#A7F3D0"
                                CornerRadius="16"
                                Padding="12,8"
                                HasShadow="False">

                                <RadioButton
                                    x:Name="IncomeRadio"
                                    GroupName="TransactionType"
                                    Content="Gelir"
                                    TextColor="#1E1B4B"
                                    FontSize="14"
                                    VerticalOptions="Center" />
                            </Frame>

                            <Frame
                                Grid.Column="1"
                                BackgroundColor="#FEF2F2"
                                BorderColor="#FECACA"
                                CornerRadius="16"
                                Padding="12,8"
                                HasShadow="False">

                                <RadioButton
                                    x:Name="ExpenseRadio"
                                    GroupName="TransactionType"
                                    Content="Gider"
                                    TextColor="#1E1B4B"
                                    FontSize="14"
                                    VerticalOptions="Center" />
                            </Frame>

                        </Grid>
                    </VerticalStackLayout>

                    <!-- Başlık -->
                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Başlık *"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Frame
                            BackgroundColor="{DynamicResource InputBackground}"
                            BorderColor="{DynamicResource BorderSoft}"
                            CornerRadius="16"
                            Padding="14,0"
                            HeightRequest="52"
                            HasShadow="False">

                            <Entry
                                x:Name="TitleEntry"
                                Placeholder="İşlem başlığı"
                                TextColor="{DynamicResource TextPrimary}"
                                PlaceholderColor="{DynamicResource TextMuted}"
                                VerticalOptions="Center" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Tutar -->
                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Tutar (₺) *"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Frame
                            BackgroundColor="{DynamicResource InputBackground}"
                            BorderColor="{DynamicResource BorderSoft}"
                            CornerRadius="16"
                            Padding="14,0"
                            HeightRequest="52"
                            HasShadow="False">

                            <Entry
                                x:Name="AmountEntry"
                                Placeholder="0,00"
                                Keyboard="Numeric"
                                TextColor="{DynamicResource TextPrimary}"
                                PlaceholderColor="{DynamicResource TextMuted}"
                                VerticalOptions="Center" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Kategori + Tarih -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="6">

                            <Label
                                Text="Kategori"
                                FontSize="13"
                                TextColor="{DynamicResource TextSecondary}"
                                FontAttributes="Bold" />

                            <Frame
                                BackgroundColor="{DynamicResource InputBackground}"
                                BorderColor="{DynamicResource BorderSoft}"
                                CornerRadius="16"
                                Padding="14,0"
                                HeightRequest="56"
                                HasShadow="False">

                                <Picker
                                    x:Name="CategoryPicker"
                                    Title="Kategori"
                                    TitleColor="{DynamicResource TextMuted}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Fill"
                                    HeightRequest="56">

                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Market</x:String>
                                            <x:String>Maaş</x:String>
                                            <x:String>Fatura</x:String>
                                            <x:String>Eğlence</x:String>
                                            <x:String>Ulaşım</x:String>
                                            <x:String>Diğer</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">

                            <Label
                                Text="Tarih"
                                FontSize="13"
                                TextColor="{DynamicResource TextSecondary}"
                                FontAttributes="Bold" />

                            <Frame
                                BackgroundColor="{DynamicResource InputBackground}"
                                BorderColor="{DynamicResource BorderSoft}"
                                CornerRadius="16"
                                Padding="14,0"
                                HeightRequest="56"
                                HasShadow="False">

                                <DatePicker
                                    x:Name="TransactionDatePicker"
                                    Format="dd.MM.yyyy"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Fill"
                                    HeightRequest="56" />
                            </Frame>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Tasarruf -->
                    <Frame
                        BackgroundColor="{DynamicResource Secondary}"
                        BorderColor="{DynamicResource BorderSoft}"
                        CornerRadius="16"
                        Padding="12,8"
                        HasShadow="False">

                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">

                            <CheckBox
                                x:Name="IsSavingCheckBox"
                                Color="{DynamicResource Primary}"
                                VerticalOptions="Center" />

                            <VerticalStackLayout Spacing="1" VerticalOptions="Center">

                                <Label
                                    Text="Tasarruf işlemi mi?"
                                    TextColor="{DynamicResource TextPrimary}"
                                    FontSize="14"
                                    FontAttributes="Bold" />

                                <Label
                                    Text="Bu işlem tasarruf hareketi olarak işaretlenir."
                                    TextColor="{DynamicResource TextSecondary}"
                                    FontSize="11" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Açıklama -->
                    <VerticalStackLayout Spacing="6">

                        <Label
                            Text="Açıklama"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}"
                            FontAttributes="Bold" />

                        <Frame
                            BackgroundColor="{DynamicResource InputBackground}"
                            BorderColor="{DynamicResource BorderSoft}"
                            CornerRadius="16"
                            Padding="14,8"
                            HeightRequest="110"
                            HasShadow="False">

                            <Editor
                                x:Name="DescriptionEditor"
                                Placeholder="İşlem detaylarını yazabilirsiniz..."
                                TextColor="{DynamicResource TextPrimary}"
                                PlaceholderColor="{DynamicResource TextMuted}"
                                VerticalOptions="Fill" />
                        </Frame>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Butonlar -->
            <VerticalStackLayout Spacing="10" Margin="0,4,0,22">

                <Button
                    Text="Değişiklikleri Kaydet"
                    Clicked="OnUpdateClicked"
                    HeightRequest="54"
                    CornerRadius="18" />

                <Button
                    Text="İşlemi Sil"
                    Clicked="OnDeleteClicked"
                    BackgroundColor="#FEF2F2"
                    TextColor="{DynamicResource ExpenseColor}"
                    BorderColor="#FECACA"
                    BorderWidth="1.5"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="18"
                    HeightRequest="54" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
